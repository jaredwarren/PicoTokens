# Port the Go stats server will listen on
PORT=8296

# Your daily spend limit in USD (displayed on the e-paper progress bar)
DAILY_BUDGET=10.00

# Gemini API Credentials (optional, for billing reference)
# Note: Standard Gemini API key. Gemini API does not currently expose billing metrics
# via a single-key API endpoint. Use the /api/update POST route to push cost metrics.
GEMINI_API_KEY="AIzaSyMockedGeminiApiKeyToShowFormat"

# Anthropic API Credentials (optional, for automatic cost polling)
# Note: The key requires Admin permissions to read organization-wide message usage.
ANTHROPIC_API_KEY="sk-ant-admin01-mockedAnthropicApiKeyStringToShowFormat"
