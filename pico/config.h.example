#ifndef _CONFIG_H_
#define _CONFIG_H_

// Wi-Fi Credentials
#define WIFI_SSID       "YOUR_WIFI_SSID"
#define WIFI_PASSWORD   "YOUR_WIFI_PASSWORD"

// Go Server Settings
#define SERVER_IP       "192.168.1.XX"  // Local IP of your Mac running the Go server
#define SERVER_PORT     "8296"           // Port the Go server is listening on

// Refresh Interval
#define REFRESH_INTERVAL_MIN   15       // How often to update the display on success (in minutes)
#define RETRY_INTERVAL_MIN     1        // How often to retry the display on connection failure (in minutes)

#endif
